index 0000000000000000000000000000000000000000..9da7b335c06b1267fc763c7cffa0329b0999bd25
--- /dev/null
+++ b/src/main/java/de/erethon/hephaestus/HItem.java
@@ -0,0 +1,89 @@
+package de.erethon.hephaestus;
+
+import de.erethon.hephaestus.HItemBehaviour;
+import net.minecraft.core.registries.BuiltInRegistries;
+import net.minecraft.resources.ResourceLocation;
+import net.minecraft.world.entity.EquipmentSlot;
+import net.minecraft.world.item.Item;
+import net.minecraft.world.item.ItemStack;
+
+public class HItem {
+
+    private final ResourceLocation id;
+    private HItemConfig config;
+    private HItemBehaviour behaviour;
+
+    private Item baseItem;
+    private ItemStack stack;
+
+
+    public HItem(ResourceLocation resourceLocation) {
+        this.id = resourceLocation;
+    }
+
+    public HItem(HItemConfig config) {
+        this.config = config;
+        this.id = config.getId();
+    }
+
+    public ResourceLocation getId() {
+        return id;
+    }
+
+    public boolean needsUpdating(ItemStack stack) {
+        return !ItemStack.matches(stack, this.stack);
+    }
+
+    public ItemStack getStack() {
+        return stack;
+    }
+
+    public org.bukkit.inventory.ItemStack getBukkitStack() {
+        return stack.getBukkitStack();
+    }
+
+    public void setBehaviour(HItemBehaviour behaviour) {
+        this.behaviour = behaviour;
+    }
+
+    public HItemBehaviour getBehaviour() {
+        return behaviour;
+    }
+
+    public HItemConfig config() {
+        return config;
+    }
+
+    public boolean isEnabled() {
+        return config.isEnabled();
+    }
+
+    public HItem replaceWith() {
+        return config.getReplaceWith();
+    }
+
+    // TODO: Call this on inventory load
+    public void update(ItemStack original) {
+        if (!needsUpdating(original)) {
+            return;
+        }
+        int count = original.getCount();
+        ItemStack updated = stack.copyWithCount(count);
+        if (config.getReplaceWith() != null) {
+            updated = config.getReplaceWith().getStack();
+        }
+    }
+
+    public void prepare() {
+        baseItem = BuiltInRegistries.ITEM.get(new ResourceLocation(config.getMojangID()));
+        stack = new ItemStack(baseItem);
+        for (EquipmentSlot slot : EquipmentSlot.values()) {
+            stack.getAttributeModifiers(slot).clear();
+        }
+        stack.getOrCreateTag().putInt("CustomModelData", config.getModelData());
+        stack.getOrCreateTag().putString("HephaestusID", id.toString());
+    }
+
+
+
+}
